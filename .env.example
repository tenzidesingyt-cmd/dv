# ════════════════════════════════════════════════════════════
# Railway.com конфигурация
# ════════════════════════════════════════════════════════════

# Для Railway:
# ENVIRONMENT=production
# PORT=8000 (устанавливается автоматически Railway)
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app (устанавливается автоматически)
# Webhook URL будет построена автоматически

# Для локальной разработки:
# ENVIRONMENT=development
# PORT=8000
# WEBHOOK_HOST=localhost
# DB_DIR=./data

