# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Ваш Telegram ID (узнать можно у @userinfobot)
ADMIN_ID=123456789

# API ключ для OpenRouter (обязательно для AI функций)
CLAUDE_API_KEY=your_openrouter_api_key_here

# API ключ для OpenAI Whisper (опционально, для лучшей транскрипции)
OPENAI_API_KEY=your_openai_api_key_here

# API ключ для Groq Whisper (опционально, альтернативная транскрипция)
GROQ_API_KEY=your_groq_api_key_here

# Telegram Payments provider token for card/e-wallet payments in KGS (not Stars)
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=KGS
